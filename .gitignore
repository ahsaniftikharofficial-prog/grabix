# ============================================================
#  GRABIX — .gitignore
#  Rule of thumb: if it's generated, downloaded, or a secret → ignore it
# ============================================================

# ─── Node / Frontend ────────────────────────────────────────
node_modules/
dist/
build/
.cache/
*.tsbuildinfo

# ─── Python / Backend ───────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.mypy_cache/

# ─── Tauri / Rust ───────────────────────────────────────────
target/
src-tauri/target/
grabix-ui/src-tauri/target/

# ─── Databases & Runtime State ──────────────────────────────
*.db
*.sqlite
*.sqlite3
memory.db

# ─── Log Files ──────────────────────────────────────────────
*.log
*.err.log
logs/
backend/logs/
consumet-local/server-watch.log
consumet-local/server-watch.err.log

# ─── Temporary / Scratch Folders ────────────────────────────
.tmp-*/
.temp-*/
tmp/
temp/

# ─── Generated / Tool Output Files ─────────────────────────
repomix-output.xml
src-only.xml
release-gate-report*.json
*.spec.bak

# ─── Downloaded Media (never commit user content) ────────────
# Only ignore actual media files — NOT the Python engine source code.
# The downloads/ package (__init__.py, engine.py) must remain tracked.
backend/downloads/*.mp4
backend/downloads/*.mkv
backend/downloads/*.webm
backend/downloads/*.m4v
backend/downloads/*.avi
backend/downloads/*.mov
backend/downloads/*.flv
backend/downloads/*.ts
backend/downloads/*.mp3
backend/downloads/*.aac
backend/downloads/*.flac
backend/downloads/*.opus
backend/downloads/*.m4a
backend/downloads/*.jpg
backend/downloads/*.jpeg
backend/downloads/*.png
backend/downloads/*.webp
backend/downloads/*.srt
backend/downloads/*.vtt
backend/downloads/*.ass
# If you store user downloads in a subdirectory, ignore the whole folder:
backend/downloads/media/

# ─── Secrets & Environment ──────────────────────────────────
.env
.env.local
.env.*.local
runtime-config.local.json
*.pem
*.key
secrets.json

# ─── OS Junk ────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ─── IDE / Editor ───────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo

# ─── Build Artifacts ────────────────────────────────────────
*.exe
*.msi
*.dmg
*.AppImage
grabix-ui/src-tauri/target/



grabix-ui/src-tauri/bin/grabix-backend/
grabix-ui/src-tauri/python-runtime/
grabix-ui/src-tauri/backend-staging/
grabix-ui/src-tauri/consumet-staging/
grabix-ui/src-tauri/generated/
debug-backend.bat
1. Backend.bat
2. Frontend.bat
3. Comsumet_api.bat
Hianime from consumet api.txt
backend/all_tests_results.txt

# ─── Anime / Consumet sidecar (removed from active development) ─────────────
consumet-local/

# ─── Scratch / temp notes ────────────────────────────────────────────────────
1804
direct
backend/test_shape_results.txt
test_shape_results.txt

# ─── Anime / Consumet sidecar (removed from active dev) ────────────────────
consumet-local/

# ─── Test result dumps ──────────────────────────────────────────────────────
backend/all_tests_results.txt
backend/test_shape_results.txt
test_shape_results.txt

# ─── Scratch/temp notes ─────────────────────────────────────────────────────
1804
direct
*.dll
