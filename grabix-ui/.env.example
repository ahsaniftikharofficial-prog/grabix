# ─────────────────────────────────────────────────────────────────────────────
# GRABIX — Frontend Environment Variables
# Rename this file to .env  (remove .example)
# ─────────────────────────────────────────────────────────────────────────────

# ── TMDB API ──────────────────────────────────────────────────────────────────
# Get your free key at: https://www.themoviedb.org/settings/api
#
# Option A — Read Access Token (recommended, starts with "eyJ")
# VITE_TMDB_TOKEN=eyJhbGciOiJSUzI1NiJ9...
#
# Option B — API Key v3 (32-character hex string)
# VITE_TMDB_KEY=abcdef1234567890abcdef1234567890

VITE_TMDB_TOKEN=
VITE_TMDB_KEY=

# ── Backend (optional — only needed for downloads/streaming features) ─────────
# VITE_GRABIX_API_BASE=http://127.0.0.1:8000
