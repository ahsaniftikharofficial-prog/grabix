<file path="grabix-ui/src/index.css">
@import url('https://fonts.googleapis.com/css2?family=Google+Sans:wght@400;500;600&family=Google+Sans+Mono&display=swap');

/* ─── fallback for Google Sans (not always available via API) ─── */
@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --font: 'Outfit', 'Google Sans', sans-serif;
  --font-mono: 'JetBrains Mono', 'Google Sans Mono', monospace;
  --radius-sm: 8px;
  --radius-md: 12px;
  --radius-lg: 16px;
  --sidebar-w: 220px;
  --topbar-h: 56px;
  --transition: 0.18s ease;
}

/* ─── LIGHT MODE ─── */
[data-theme="light"] {
  --bg-app:       #f8f9fa;
  --bg-sidebar:   #ffffff;
  --bg-surface:   #ffffff;
  --bg-surface2:  #f1f3f4;
  --bg-hover:     #f1f3f4;
  --bg-active:    #e8f0fe;
  --bg-input:     #ffffff;
  --bg-overlay:   rgba(0,0,0,0.04);

  --border:       #e0e0e0;
  --border-focus: #1a73e8;

  --text-primary:   #202124;
  --text-secondary: #5f6368;
  --text-muted:     #9aa0a6;
  --text-accent:    #1a73e8;
  --text-on-accent: #ffffff;
  --text-danger:    #d93025;
  --text-success:   #188038;
  --text-warning:   #f29900;

  --accent:         #1a73e8;
  --accent-hover:   #1557b0;
  --accent-light:   #e8f0fe;
  --accent-subtle:  #f0f4ff;

  --danger:         #d93025;
  --success:        #188038;
  --warning:        #f29900;

  --shadow-sm:  0 1px 3px rgba(60,64,67,0.12), 0 1px 2px rgba(60,64,67,0.08);
  --shadow-md:  0 2px 6px rgba(60,64,67,0.15), 0 1px 3px rgba(60,64,67,0.10);
  --shadow-lg:  0 4px 16px rgba(60,64,67,0.18), 0 2px 6px rgba(60,64,67,0.12);
}

/* ─── DARK MODE ─── */
[data-theme="dark"] {
  --bg-app:       #111213;
  --bg-sidebar:   #1a1b1e;
  --bg-surface:   #1e2023;
  --bg-surface2:  #26282c;
  --bg-hover:     #26282c;
  --bg-active:    #1e3a5f;
  --bg-input:     #26282c;
  --bg-overlay:   rgba(255,255,255,0.04);

  --border:       #2e3034;
  --border-focus: #8ab4f8;

  --text-primary:   #e8eaed;
  --text-secondary: #9aa0a6;
  --text-muted:     #5f6368;
  --text-accent:    #8ab4f8;
  --text-on-accent: #202124;
  --text-danger:    #f28b82;
  --text-success:   #81c995;
  --text-warning:   #fdd663;

  --accent:         #8ab4f8;
  --accent-hover:   #aecbfa;
  --accent-light:   #1e3a5f;
  --accent-subtle:  #1a2840;

  --danger:         #f28b82;
  --success:        #81c995;
  --warning:        #fdd663;

  --shadow-sm:  0 1px 3px rgba(0,0,0,0.4);
  --shadow-md:  0 2px 8px rgba(0,0,0,0.5);
  --shadow-lg:  0 4px 20px rgba(0,0,0,0.6);
}

/* ─── BASE ─── */
html, body, #root {
  height: 100%;
  width: 100%;
  font-family: var(--font);
  background: var(--bg-app);
  color: var(--text-primary);
  font-size: 14px;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}

/* ─── SCROLLBAR ─── */
::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 99px; }
::-webkit-scrollbar-thumb:hover { background: var(--text-muted); }

/* ─── TRIM SLIDER ─── */
.trim-range-track {
  position: relative;
  height: 36px;
  display: flex;
  align-items: center;
}
.trim-range-track input[type="range"] {
  position: absolute;
  width: 100%;
  height: 4px;
  appearance: none;
  background: transparent;
  pointer-events: none;
  outline: none;
}
.trim-range-track input[type="range"]::-webkit-slider-thumb {
  appearance: none;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  background: var(--accent);
  border: 2px solid var(--bg-surface);
  box-shadow: var(--shadow-sm);
  pointer-events: all;
  cursor: grab;
  transition: transform 0.1s;
}
.trim-range-track input[type="range"]::-webkit-slider-thumb:active { cursor: grabbing; transform: scale(1.15); }
.trim-track-bg {
  position: absolute;
  left: 0; right: 0;
  height: 4px;
  background: var(--border);
  border-radius: 99px;
}
.trim-track-fill {
  position: absolute;
  height: 4px;
  background: var(--accent);
  border-radius: 99px;
}

/* ─── QUALITY CHIP ─── */
.quality-chip {
  padding: 5px 12px;
  border-radius: 99px;
  font-size: 12px;
  font-weight: 500;
  border: 1.5px solid var(--border);
  background: transparent;
  color: var(--text-secondary);
  cursor: pointer;
  transition: all var(--transition);
  font-family: var(--font);
}
.quality-chip:hover { border-color: var(--accent); color: var(--text-accent); background: var(--accent-subtle); }
.quality-chip.active { border-color: var(--accent); color: var(--text-accent); background: var(--accent-light); }

/* ─── FILE TYPE TAB ─── */
.filetype-tab {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 8px 16px;
  border-radius: var(--radius-sm);
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  transition: all var(--transition);
  border: 1.5px solid var(--border);
  background: transparent;
  color: var(--text-secondary);
  font-family: var(--font);
}
.filetype-tab:hover { border-color: var(--accent); color: var(--text-accent); background: var(--accent-subtle); }
.filetype-tab.active { border-color: var(--accent); color: var(--text-accent); background: var(--accent-light); font-weight: 600; }

/* ─── BUTTON BASE ─── */
.btn { display: inline-flex; align-items: center; gap: 6px; font-family: var(--font); font-weight: 500; font-size: 13px; border-radius: var(--radius-sm); cursor: pointer; transition: all var(--transition); border: none; outline: none; padding: 0 16px; height: 36px; white-space: nowrap; }
.btn:disabled { opacity: 0.45; cursor: not-allowed; }
.btn-primary { background: var(--accent); color: var(--text-on-accent); }
.btn-primary:hover:not(:disabled) { background: var(--accent-hover); }
.btn-secondary { background: transparent; color: var(--text-accent); border: 1.5px solid var(--accent); }
.btn-secondary:hover:not(:disabled) { background: var(--accent-light); }
.btn-ghost { background: transparent; color: var(--text-secondary); border: 1.5px solid var(--border); }
.btn-ghost:hover:not(:disabled) { background: var(--bg-hover); color: var(--text-primary); border-color: var(--text-muted); }
.btn-danger { background: var(--danger); color: white; }
.btn-danger:hover:not(:disabled) { opacity: 0.88; }
.btn-icon { width: 36px; height: 36px; padding: 0; display: inline-flex; align-items: center; justify-content: center; border-radius: var(--radius-sm); background: transparent; border: 1.5px solid var(--border); color: var(--text-secondary); cursor: pointer; transition: all var(--transition); }
.btn-icon:hover { background: var(--bg-hover); color: var(--text-primary); border-color: var(--text-muted); }

/* ─── INPUT ─── */
.input-base {
  width: 100%;
  height: 44px;
  padding: 0 14px;
  border-radius: var(--radius-md);
  border: 1.5px solid var(--border);
  background: var(--bg-input);
  color: var(--text-primary);
  font-family: var(--font);
  font-size: 14px;
  outline: none;
  transition: border-color var(--transition), box-shadow var(--transition);
}
.input-base::placeholder { color: var(--text-muted); }
.input-base:focus { border-color: var(--border-focus); box-shadow: 0 0 0 3px var(--accent-subtle); }

/* ─── CARD ─── */
.card { background: var(--bg-surface); border: 1px solid var(--border); border-radius: var(--radius-lg); }
.card-padded { padding: 20px; }

/* ─── SIDEBAR NAV ─── */
.nav-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 9px 12px;
  border-radius: var(--radius-sm);
  font-size: 13.5px;
  font-weight: 500;
  cursor: pointer;
  transition: all var(--transition);
  color: var(--text-secondary);
  margin-bottom: 2px;
  user-select: none;
}
.nav-item:hover { background: var(--bg-hover); color: var(--text-primary); }
.nav-item.active { background: var(--bg-active); color: var(--text-accent); }
.nav-badge { margin-left: auto; background: var(--accent); color: var(--text-on-accent); font-size: 10px; font-weight: 600; padding: 2px 7px; border-radius: 99px; min-width: 18px; text-align: center; }

/* ─── PROGRESS BAR ─── */
.progress-bar-bg { height: 4px; background: var(--bg-surface2); border-radius: 99px; overflow: hidden; }
.progress-bar-fill { height: 100%; background: var(--accent); border-radius: 99px; transition: width 0.5s ease; }

/* ─── STATUS DOT ─── */
.status-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
.status-dot.online { background: var(--success); }
.status-dot.offline { background: var(--danger); }
.status-dot.busy { background: var(--warning); }

/* ─── TOOLTIP ─── */
.tooltip-wrap { position: relative; display: inline-flex; }
.tooltip-wrap:hover .tooltip-box { opacity: 1; pointer-events: none; }
.tooltip-box { position: absolute; bottom: calc(100% + 6px); left: 50%; transform: translateX(-50%); background: var(--text-primary); color: var(--bg-surface); font-size: 11px; padding: 4px 8px; border-radius: 6px; white-space: nowrap; opacity: 0; transition: opacity 0.15s; pointer-events: none; z-index: 99; }

/* ─── DIVIDER ─── */
.divider { height: 1px; background: var(--border); margin: 12px 0; }

/* ─── EMPTY STATE ─── */
.empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 10px; padding: 60px 20px; color: var(--text-muted); text-align: center; }
.empty-state svg { opacity: 0.35; }
.empty-state p { font-size: 14px; }
.empty-state span { font-size: 12px; color: var(--text-muted); }

/* ─── ANIMATE ─── */
@keyframes fadeSlideIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
.fade-in { animation: fadeSlideIn 0.22s ease forwards; }
@keyframes spin { to { transform: rotate(360deg); } }
.spin { animation: spin 0.8s linear infinite; }
@keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.45; } }
.pulse { animation: pulse 1.4s ease-in-out infinite; }

.player-action-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  height: 36px;
  padding: 0 14px;
  border-radius: 12px;
  border: 1px solid rgba(255,255,255,0.1);
  background: rgba(255,255,255,0.04);
  color: rgba(255,255,255,0.86);
  cursor: pointer;
  transition: all var(--transition);
  font-family: var(--font);
  font-size: 12px;
  font-weight: 600;
}
.player-action-btn:hover:not(:disabled) {
  background: rgba(255,255,255,0.1);
  border-color: rgba(255,255,255,0.18);
}
.player-action-btn:disabled {
  opacity: 0.45;
