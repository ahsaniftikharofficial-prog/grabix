  color: rgba(255,255,255,0.88);
  cursor: pointer;
  text-align: left;
  font-family: var(--font);
}
.player-popover-item:hover,
.player-popover-item.active {
  background: rgba(255,255,255,0.1);
}
.player-popover-item small {
  color: rgba(255,255,255,0.54);
  font-size: 11px;
}
.player-mini-note {
  color: rgba(255,255,255,0.56);
  font-size: 11px;
  line-height: 1.55;
  padding: 2px 4px 0;
}
.player-right-note {
  color: rgba(255,255,255,0.72);
  font-size: 12px;
  padding: 0 4px;
}
.player-floating-status {
  position: absolute;
  top: 24px;
  left: 24px;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  max-width: min(440px, calc(100vw - 48px));
  padding: 12px 16px;
  border-radius: 16px;
  border: 1px solid rgba(255,255,255,0.1);
  background: rgba(8,10,14,0.8);
  color: rgba(255,255,255,0.84);
  font-size: 12px;
  backdrop-filter: blur(16px);
  z-index: 2;
}

@media (max-width: 720px) {
  .player-controls-wrap {
    left: 16px;
    right: 16px;
    bottom: 16px;
  }
  .player-controls-wrap.compact {
    right: 14px;
    top: 14px;
    left: auto;
    bottom: auto;
  }
  .player-control-row {
    align-items: stretch;
  }
  .player-right-note {
    width: 100%;
    padding-top: 4px;
  }
  .player-popover,
  .player-popover.narrow {
    width: min(280px, calc(100vw - 32px));
  }
}
