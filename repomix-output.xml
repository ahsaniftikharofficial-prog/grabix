}
.player-source-chip:hover {
  background: rgba(255,255,255,0.08);
  color: rgba(255,255,255,0.9);
}
.player-source-chip.active {
  background: rgba(93,156,236,0.16);
  border-color: rgba(120,177,255,0.28);
  color: #fff;
}
.player-overlay {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10px;
  background:
    radial-gradient(circle at center, rgba(25,46,79,0.18), rgba(6,8,12,0.7) 58%),
    linear-gradient(180deg, rgba(5,8,12,0.24), rgba(5,8,12,0.82));
  text-align: center;
  padding: 20px;
}
.player-loader {
  width: 42px;
  height: 42px;
  border-radius: 50%;
  border: 3px solid rgba(255,255,255,0.12);
  border-top-color: #8ab4f8;
  animation: spin 0.8s linear infinite;
}
.player-overlay-title {
  font-size: 16px;
  font-weight: 700;
  color: #fff;
}
.player-overlay-subtitle {
  font-size: 12px;
  color: rgba(255,255,255,0.62);
  max-width: 420px;
  line-height: 1.6;
}
.player-assist-card {
  position: absolute;
  left: 20px;
  bottom: 20px;
  max-width: 360px;
  padding: 14px 16px;
  border-radius: 16px;
  border: 1px solid rgba(255,255,255,0.1);
  background: rgba(10,14,20,0.78);
  backdrop-filter: blur(14px);
  box-shadow: 0 14px 36px rgba(0,0,0,0.35);
}
.player-status-banner {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 20px;
  background: rgba(22,34,48,0.88);
  border-bottom: 1px solid rgba(255,255,255,0.06);
  color: rgba(255,255,255,0.82);
  font-size: 12px;
}
.player-status-banner.error {
  background: rgba(66,26,26,0.88);
  color: #ffd0cb;
}
.player-video {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  background: #000;
  display: block;
  object-fit: contain;
}
.player-meta-pill {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  height: 34px;
  padding: 0 14px;
  border-radius: 999px;
  background: rgba(10,14,20,0.74);
  border: 1px solid rgba(255,255,255,0.08);
  color: rgba(255,255,255,0.72);
  font-size: 11px;
  backdrop-filter: blur(14px);
}
.player-shell {
  position: fixed;
  inset: 0;
  z-index: 500;
  background: #000;
  overflow: hidden;
  cursor: default;
}
.player-frame {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  border: none;
  background: #000;
  display: block;
}
.player-hover-ui {
  position: absolute;
  inset: 0;
  pointer-events: none;
  opacity: 0;
  transition: opacity 0.22s ease;
}
.player-hover-ui.visible {
  opacity: 1;
}
.player-hover-ui.compact .player-top-fade {
  height: 90px;
  background: linear-gradient(180deg, rgba(0,0,0,0.52), transparent);
}
.player-top-fade,
.player-bottom-fade {
  position: absolute;
  left: 0;
  right: 0;
  pointer-events: none;
}
.player-top-fade {
  top: 0;
  height: 140px;
  background: linear-gradient(180deg, rgba(0,0,0,0.72), transparent);
}
.player-bottom-fade {
  bottom: 0;
  height: 220px;
  background: linear-gradient(0deg, rgba(0,0,0,0.82), transparent);
}
.player-controls-wrap {
  position: absolute;
  left: 28px;
  right: 28px;
  bottom: 26px;
  pointer-events: auto;
}
.player-controls-wrap.compact {
  left: auto;
  right: 22px;
  top: 18px;
  bottom: auto;
}
.player-timeline {
  display: flex;
  align-items: center;
  gap: 12px;
  color: rgba(255,255,255,0.82);
